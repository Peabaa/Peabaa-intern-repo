{
  "extends": ["airbnb-base", "prettier"],
  "env": {
    "node": true,
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "rules": {
    "import/no-unresolved": [
      "error",
      { "ignore": ["^vite$", "^@vitejs/plugin-react$"] }
    ],
    "import/no-extraneous-dependencies": [
      "error",
      { "devDependencies": ["vite.config.js"] }
    ]
  }
}
