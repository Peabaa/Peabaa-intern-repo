{
  "extends": [
    "airbnb-base",
    "plugin:react/recommended",
    "plugin:react/jsx-runtime",
    "prettier"
  ],
  "plugins": ["react"],
  "env": {
    "node": true,
    "browser": true,
    "es2021": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "rules": {
    "import/no-unresolved": [
      "error",
      { "ignore": ["^vite$", "^@vitejs/plugin-react$"] }
    ],
    "import/no-extraneous-dependencies": [
      "error",
      { "devDependencies": ["vite.config.js", "**/*.test.js", "**/*.test.jsx"] }
    ],
    "no-param-reassign": [
      "error",
      { "props": true, "ignorePropertyModificationsFor": ["state"] }
    ],
    "react/prop-types": "off"
  }
}
